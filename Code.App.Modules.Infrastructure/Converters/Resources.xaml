<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Code.App.Modules.Infrastructure.Converters">

    <!-- Converters -->
    <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <converters:IntToBrushConverter x:Key="IntToBrushConverter"/>
    <converters:LanguageCodeToDisplayConverter x:Key="LanguageCodeToDisplayConverter"/>
    <converters:RequiredValidationRule x:Key="RequiredValidationRule"/>
    <converters:LeadingZeroConverter x:Key="LeadingZeroConverter"/>

    <!-- TextBox Validation -->
    <Style TargetType="TextBox">
        <Setter Property="Margin" Value="0,5,0,15"/>

        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="Red"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>

    <!-- DataGrid Display Style -->
    <Style x:Key="DataGridTextBlockStyle"
           TargetType="TextBlock">

        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="5,0"/>

    </Style>

    <!-- DataGrid Editing Style -->
    <Style x:Key="DataGridEditingTextBoxStyle"
           TargetType="TextBox">

        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="5,0"/>
        <Setter Property="TextAlignment" Value="Center"/>

    </Style>

</ResourceDictionary>